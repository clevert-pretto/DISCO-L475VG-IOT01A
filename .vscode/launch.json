{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug for 03_FreeRTOS",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}/03_FreeRTOS",
            "executable": "${workspaceFolder}/03_FreeRTOS/build/freeRTOSApp.elf",
            "device": "STM32L475",
            "interface": "swd",
            "runToEntryPoint": "main",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32l4x.cfg"
            ],
            /* This is the key: it triggers the dropdown menu from tasks.json */
            "preLaunchTask": "Build 03_FreeRTOS",
            /* Important for WSL: points to the gdb you installed */
            "gdbPath": "/usr/bin/gdb-multiarch",
        },
        {
            "name": "Cortex Debug (CMake) for 04_FreeRTOS_Cpp",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}/04_FreeRTOS_Cpp",
            "executable": "${workspaceFolder}/04_FreeRTOS_Cpp/build/freeRTOSApp.elf",
            "device": "STM32L475",
            "interface": "swd",
            "runToEntryPoint": "main",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32l4x.cfg"
            ],
            /* This is the key: it triggers the dropdown menu from tasks.json */
            "preLaunchTask": "CMake Build 04_FreeRTOS_Cpp",
            /* Important for WSL: points to the gdb you installed */
            "gdbPath": "/usr/bin/gdb-multiarch"
        }
    ]
}